{
  "name": "lll-client",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --watch",
    "dev": "node scripts/dev-with-emit.mjs",
    "dev:vite": "vite",
    "dev:emit": "tsc -w --preserveWatchOutput",
    "lll-server": "lllts --server start --port 27453 --projectPath . --projectClientLink http://localhost:27451",
    "lll-check": "lllts --project tsconfig.json --entry src/Start.lll.ts --clientTunnel http://localhost:27453",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "i": "corepack pnpm i"
  },
  "dependencies": {
    "lit": "^3.2.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "lllts": "file:../.lll/vendor/lllts"
  }
}
